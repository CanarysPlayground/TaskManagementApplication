{
  "name": "task-management-api",
  "version": "1.0.0",
  "description": "Minimal Express.js Task API",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev:api": "ts-node server.ts",
    "dev:ui": "vite",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:ui\""
  },
  "dependencies": {
    "express": "^4.18.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vite": "^8.0.3"
  }
}
